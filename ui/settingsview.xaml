<UserControl x:Class="flowx.ui.settingsview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="480"
             PreviewMouseWheel="OnPreviewMouseWheel"
             RequestBringIntoView="OnRequestBringIntoView">

    <UserControl.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="FlowxGroupBoxTemplate" TargetType="GroupBox">
            <Border CornerRadius="10"
                    BorderThickness="4"
                    BorderBrush="#5A5A5A"
                    Background="Transparent"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ContentPresenter Grid.Row="0" ContentSource="Header" Margin="0,0,0,8"/>
                    <ContentPresenter Grid.Row="1" ContentSource="Content"/>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="changes are saved automatically."
                   Margin="18,0,0,8"
                   Foreground="#888"/>

        <GroupBox Grid.Row="1" Template="{StaticResource FlowxGroupBoxTemplate}" Margin="0,0,0,8">
            <GroupBox.Header>
                <TextBlock Text="sharex folder" Style="{StaticResource HeaderText}"/>
            </GroupBox.Header>
            <StackPanel Margin="10">
                <TextBox x:Name="ShareXPathBox"/>
                <TextBlock Opacity="0.7" Margin="0,6,0,0" Text="path to folder containing sharex.exe"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Template="{StaticResource FlowxGroupBoxTemplate}">
            <GroupBox.Header>
                <TextBlock Text="commands" Style="{StaticResource HeaderText}"/>
            </GroupBox.Header>
            <DockPanel Margin="10" LastChildFill="True" ClipToBounds="False">
                <Border DockPanel.Dock="Top"
                        HorizontalAlignment="Left"
                        CornerRadius="8"
                        BorderThickness="2"
                        BorderBrush="#5A5A5A"
                        Background="Transparent"
                        Padding="10,6"
                        Margin="0,0,0,10">
                    <Button x:Name="PresetToggleBtn"
                            Content="recommended"
                            MinWidth="124"
                            Padding="14,8"
                            HorizontalContentAlignment="Center"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="CommandsPanel"/>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>
